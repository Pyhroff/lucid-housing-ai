# Copy this file to `.env` and fill in ONE provider's key. Never commit `.env`.

# Which provider to use: "groq" (default) or "gemini"
LLM_PROVIDER=groq

# --- Groq (free, fast Llama): https://console.groq.com/keys ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Gemini (free tier): https://aistudio.google.com/app/apikey ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- tuning (optional) ---
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3
